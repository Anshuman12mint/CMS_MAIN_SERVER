APP_NAME=college-server
APP_ENV=development
APP_VERSION=0.1.0
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO
DOCS_ENABLED=true

DB_URL=postgresql://postgres:postgres@localhost:5432/college_server
DB_USERNAME=
DB_PASSWORD=
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_PRE_PING=true
AUTO_INITIALIZE_SCHEMA=false
RUN_MIGRATIONS_ON_STARTUP=false

JWT_SECRET=change-this-secret-key-change-this-secret-key
JWT_ISSUER=college-server
JWT_AUDIENCE=college-clients
JWT_EXPIRATION_MINUTES=120
JWT_LEEWAY_SECONDS=5
REFRESH_TOKEN_EXPIRATION_DAYS=14
MAX_ACTIVE_REFRESH_TOKENS_PER_USER=5

LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_LOCKOUT_SECONDS=900

BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin12345
BOOTSTRAP_ADMIN_EMAIL=admin@college.com

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
TRUSTED_HOSTS=localhost,127.0.0.1,::1,testserver
REQUEST_ID_HEADER_NAME=X-Request-ID
